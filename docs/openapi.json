          {
            "arxiv_id": "1706.03762",
            "authors": "Ashish Vaswani, Noam Shazeer",
            "categories": "cs.CL cs.LG",
            "interaction_count": 14,
            "last_interacted_at": "2025-03-10T11:42:00Z",
