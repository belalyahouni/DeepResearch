    }
  },
  "components": {
    "schemas": {
      "ArxivPaperResponse": {
        "properties": {
          "arxiv_id": {
            "type": "string",
            "title": "Arxiv Id",
            "description": "arXiv paper ID (e.g. 1706.03762)"
          },
          "title": {
            "type": "string",
            "title": "Title",
            "description": "Paper title"
          },
          "authors": {
            "type": "string",
            "title": "Authors",
            "description": "Comma-separated author names"
          },
          "abstract": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Abstract",
            "description": "Paper abstract"
          },
          "categories": {
            "type": "string",
            "title": "Categories",
            "description": "Space-separated arXiv categories"
          },
          "year": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Year",
            "description": "Publication year"
          },
          "doi": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Doi",
            "description": "Digital Object Identifier"
          },
          "url": {
            "type": "string",
            "title": "Url",
            "description": "arXiv URL"
          },
          "similarity_score": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Similarity Score",
            "description": "Cosine similarity score from vector search (0-1)"
          }
        },
        "type": "object",
        "required": [
          "arxiv_id",
          "title",
          "authors",
          "categories",
          "url"
        ],
        "title": "ArxivPaperResponse",
        "description": "Schema for returning an arXiv paper from the corpus.",
        "examples": [
          {
            "abstract": "The dominant sequence transduction models are based on complex recurrent or convolutional neural networks...",
            "arxiv_id": "1706.03762",
            "authors": "Ashish Vaswani, Noam Shazeer, Niki Parmar, Jakob Uszkoreit, Llion Jones, Aidan N. Gomez, Lukasz Kaiser, Illia Polosukhin",
            "categories": "cs.CL cs.LG",
            "doi": "10.48550/arXiv.1706.03762",
            "similarity_score": 0.92,
            "title": "Attention Is All You Need",
            "url": "https://arxiv.org/abs/1706.03762",
            "year": 2017
          }
        ]
      },
      "CommunityListResponse": {
        "properties": {
          "total": {
            "type": "integer",
            "title": "Total",
            "description": "Number of papers returned"
          },
          "papers": {
            "items": {
              "$ref": "#/components/schemas/CommunityPaperResponse"
            },
            "type": "array",
            "title": "Papers",
            "description": "Papers ranked by interaction count"
          }
        },
        "type": "object",
        "required": [
          "total",
          "papers"
        ],
        "title": "CommunityListResponse",
        "description": "Response from the community popular papers endpoint.",
        "examples": [
          {
            "papers": [
              {
                "arxiv_id": "1706.03762",
                "authors": "Ashish Vaswani, Noam Shazeer",
                "categories": "cs.CL cs.LG",
                "interaction_count": 14,
                "last_interacted_at": "2025-03-10T11:42:00Z",
                "title": "Attention Is All You Need",
                "url": "https://arxiv.org/abs/1706.03762",
                "year": 2017
              }
            ],
            "total": 1
          }
        ]
      },
