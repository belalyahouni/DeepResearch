          "title": {
            "type": "string",
            "title": "Title",
            "description": "Paper title"
          },
          "authors": {
            "type": "string",
            "title": "Authors",
            "description": "Comma-separated author names"
          },
          "categories": {
            "type": "string",
            "title": "Categories",
            "description": "Space-separated arXiv categories"
          },
          "year": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Year",
            "description": "Publication year"
          },
          "url": {
            "type": "string",
            "title": "Url",
            "description": "arXiv URL"
          }
        },
        "type": "object",
        "required": [
          "arxiv_id",
          "interaction_count",
          "last_interacted_at",
          "title",
          "authors",
          "categories",
          "url"
        ],
        "title": "CommunityPaperResponse",
