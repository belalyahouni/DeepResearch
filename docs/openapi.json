{
  "openapi": "3.1.0",
  "info": {
    "title": "DeepResearch API",
    "description": "An agentic research assistant API for discovering and exploring AI/ML academic papers. Features a 3-agent pipeline (classifier \u2192 query optimiser \u2192 BGE vector search) powered by Google Gemini, with `BAAI/bge-base-en-v1.5` cosine similarity search over a local arXiv AI/ML corpus (~521k papers). Summarisation via Gemini. Built with FastAPI, SQLAlchemy, ChromaDB, and SQLite. Authenticate via the `X-API-Key` header on all endpoints except `/health`.",
    "version": "2.0.0"
  },
  "paths": {
    "/papers/{arxiv_id}": {
      "get": {
        "tags": [
          "Papers"
        ],
        "summary": "Get a paper from the corpus",
        "description": "Look up an arXiv paper by its ID from the local AI/ML corpus.",
        "operationId": "get_paper_papers__arxiv_id__get",
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "parameters": [
          {
            "name": "arxiv_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Arxiv Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ArxivPaperResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key"
          },
          "404": {
            "description": "Paper not found in the corpus"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/papers/{arxiv_id}/related": {
      "get": {
        "tags": [
          "Papers"
        ],
        "summary": "Find related papers",
        "description": "Find papers related to the given arXiv paper using BGE vector similarity.\nReturns up to 5 related papers from the corpus.",
        "operationId": "related_papers_papers__arxiv_id__related_get",
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "parameters": [
          {
            "name": "arxiv_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Arxiv Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ArxivPaperResponse"
                  },
                  "title": "Response Related Papers Papers  Arxiv Id  Related Get"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key"
          },
          "404": {
            "description": "Paper not found in the corpus or vector store"
          },
          "500": {
            "description": "Vector search failure"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/search": {
      "get": {
        "tags": [
          "Search"
        ],
        "summary": "Search for academic papers",
        "description": "Run the full agentic search pipeline: classify the arXiv AI/ML category,\noptimise the query, then perform BGE vector similarity search\nover the local arXiv AI/ML corpus.",
        "operationId": "search_search_get",
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "description": "Search query for academic papers",
              "title": "Query"
            },
            "description": "Search query for academic papers"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key"
          },
          "422": {
            "description": "Validation error \u2014 query parameter is required"
          },
          "500": {
            "description": "Vector search or Gemini agent failure"
          }
        }
      }
    },
    "/summarise": {
      "post": {
        "tags": [
          "Summarisation"
        ],
        "summary": "Summarise academic text",
        "description": "Summarise any academic text using the Gemini summariser agent.\nPass an abstract for a quick preview, or the full paper text for a\ncomprehensive summary. Provide arxiv_id to record this interaction in\nthe community index.",
        "operationId": "summarise_summarise_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SummariseRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SummariseResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key"
          },
          "422": {
            "description": "Validation error \u2014 text field is required and must not be empty"
          },
          "429": {
            "description": "Rate limit exceeded \u2014 max 5 requests per minute"
          },
          "500": {
            "description": "Gemini summarisation agent failure"
          }
        },
        "security": [
          {
            "APIKeyHeader": []
          }
        ]
      }
    },
    "/community": {
      "get": {
        "tags": [
          "Community"
        ],
        "summary": "List most popular papers",
        "description": "Returns papers ranked by community interaction count. A paper enters this index the first time it is directly accessed or summarised. Count increments on: direct paper lookup, summarisation, and related-papers queries.",
        "operationId": "list_community_papers_community_get",
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "description": "Number of papers to return (max 100)",
              "default": 20,
              "title": "Limit"
            },
            "description": "Number of papers to return (max 100)"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommunityListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/community/{arxiv_id}": {
      "get": {
        "tags": [
          "Community"
        ],
        "summary": "Get community stats for a paper",
        "description": "Returns the interaction count and last activity timestamp for a specific paper. A paper only appears here once it has been accessed via GET /papers/{arxiv_id}, POST /summarise (with arxiv_id), or GET /papers/{arxiv_id}/related.",
        "operationId": "get_community_paper_community__arxiv_id__get",
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "parameters": [
          {
            "name": "arxiv_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Arxiv Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CommunityPaperResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key"
          },
          "404": {
            "description": "Paper has not been interacted with yet \u2014 not in the community index"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/papers/{arxiv_id}/notes": {
