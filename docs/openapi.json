            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/NoteResponse"
                  },
                  "title": "Response List Notes Papers  Arxiv Id  Notes Get"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key"
          },
          "404": {
            "description": "Paper not found in corpus"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
