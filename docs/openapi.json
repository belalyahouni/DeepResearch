        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "parameters": [
          {
            "name": "arxiv_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Arxiv Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NoteCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NoteResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key"
          },
          "404": {
            "description": "Paper not found in corpus"
          },
          "422": {
            "description": "Validation error \u2014 content is required"
          },
          "429": {
            "description": "Rate limit exceeded \u2014 max 10 notes per minute"
          }
        }
      },
      "get": {
        "tags": [
          "Notes"
        ],
        "summary": "Get all notes for a paper",
        "description": "Retrieve all public notes attached to a specific arXiv paper.",
        "operationId": "list_notes_papers__arxiv_id__notes_get",
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "parameters": [
          {
